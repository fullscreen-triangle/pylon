 `Super<Self>`.\n"},"level":"error","spans":[{"file_name":"..\\..\\src\\cables\\individual.rs","byte_start":17752,"byte_end":17774,"line_start":557,"line_end":557,"column_start":49,"column_end":71,"is_primary":true,"text":[{"text":"    measurement_algorithms: HashMap<String, Arc<dyn ExperienceMeasurer>>,","highlight_start":49,"highlight_end":71}],"label":"`ExperienceMeasurer` is not dyn compatible","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"for a trait to be dyn compatible it needs to allow building a vtable\nfor more information, visit <https://doc.rust-lang.org/reference/items/traits.html#dyn-compatibility>","code":null,"level":"note","spans":[{"file_name":"..\\..\\src\\cables\\individual.rs","byte_start":18116,"byte_end":18134,"line_start":567,"line_end":567,"column_start":11,"column_end":29,"is_primary":false,"text":[{"text":"pub trait ExperienceMeasurer: Send + Sync {","highlight_start":11,"highlight_end":29}],"label":"this trait is not dyn compatible...","suggested_replacement":null,"suggestion_applicability":null,"expansion":null},{"file_name":"..\\..\\src\\cables\\individual.rs","byte_start":18211,"byte_end":18229,"line_start":569,"line_end":569,"column_start":14,"column_end":32,"is_primary":true,"text":[{"text":"    async fn measure_experience(","highlight_start":14,"highlight_end":32}],"label":"...because method `measure_experience` is `async`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"consider moving `measure_experience` to another trait","code":null,"level":"help","spans":[],"children":[],"rendered":null}],"rendered":"..\\..\\src\\cables\\individual.rs:557:49: \u001b[1m\u001b[91merror[E0038]\u001b[0m: the trait `ExperienceMeasurer` is not dyn compatible: `ExperienceMeasurer` is not dyn compatible\n"}
