ve from `Super<Self>`.\n"},"level":"error","spans":[{"file_name":"..\\..\\src\\cables\\network.rs","byte_start":10935,"byte_end":10964,"line_start":324,"line_end":324,"column_start":33,"column_end":62,"is_primary":true,"text":[{"text":"    distribution_algorithm: Arc<dyn TimeDistributionAlgorithm>,","highlight_start":33,"highlight_end":62}],"label":"`TimeDistributionAlgorithm` is not dyn compatible","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"for a trait to be dyn compatible it needs to allow building a vtable\nfor more information, visit <https://doc.rust-lang.org/reference/items/traits.html#dyn-compatibility>","code":null,"level":"note","spans":[{"file_name":"..\\..\\src\\cables\\network.rs","byte_start":11488,"byte_end":11513,"line_start":343,"line_end":343,"column_start":11,"column_end":36,"is_primary":false,"text":[{"text":"pub trait TimeDistributionAlgorithm: Send + Sync {","highlight_start":11,"highlight_end":36}],"label":"this trait is not dyn compatible...","suggested_replacement":null,"suggestion_applicability":null,"expansion":null},{"file_name":"..\\..\\src\\cables\\network.rs","byte_start":11592,"byte_end":11614,"line_start":345,"line_end":345,"column_start":14,"column_end":36,"is_primary":true,"text":[{"text":"    async fn distribute_time_update(","highlight_start":14,"highlight_end":36}],"label":"...because method `distribute_time_update` is `async`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"consider moving `distribute_time_update` to another trait","code":null,"level":"help","spans":[],"children":[],"rendered":null},{"message":"only type `cables::network::SimpleTimeDistribution` implements `TimeDistributionAlgorithm` within this crate; consider using it directly instead.","code":null,"level":"help","spans":[],"children":[],"rendered":null},{"message":"`TimeDistributionAlgorithm` may be implemented in other crate