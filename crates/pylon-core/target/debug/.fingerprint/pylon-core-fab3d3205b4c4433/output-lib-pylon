e from `Super<Self>`.\n"},"level":"error","spans":[{"file_name":"..\\..\\src\\cables\\individual.rs","byte_start":40169,"byte_end":40183,"line_start":1272,"line_end":1272,"column_start":32,"column_end":46,"is_primary":true,"text":[{"text":"            access_algorithms: HashMap::new(),","highlight_start":32,"highlight_end":46}],"label":"`CognitiveAccessAlgorithm` is not dyn compatible","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"for a trait to be dyn compatible it needs to allow building a vtable\nfor more information, visit <https://doc.rust-lang.org/reference/items/traits.html#dyn-compatibility>","code":null,"level":"note","spans":[{"file_name":"..\\..\\src\\cables\\individual.rs","byte_start":11530,"byte_end":11554,"line_start":362,"line_end":362,"column_start":11,"column_end":35,"is_primary":false,"text":[{"text":"pub trait CognitiveAccessAlgorithm: Send + Sync {","highlight_start":11,"highlight_end":35}],"label":"this trait is not dyn compatible...","suggested_replacement":null,"suggestion_applicability":null,"expansion":null},{"file_name":"..\\..\\src\\cables\\individual.rs","byte_start":11633,"byte_end":11648,"line_start":364,"line_end":364,"column_start":14,"column_end":29,"is_primary":true,"text":[{"text":"    async fn access_solution(","highlight_start":14,"highlight_end":29}],"label":"...because method `access_solution` is `async`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"consider moving `access_solution` to another trait","code":null,"level":"help","spans":[],"children":[],"rendered":null}],"rendered":"..\\..\\src\\cables\\individual.rs:1272:32: \u001b[1m\u001b[91merror[E0038]\u001b[0m: the trait `CognitiveAccessAlgorithm` is not dyn compatible: `CognitiveAccessAlgorithm` is not dyn compatible\n"}
